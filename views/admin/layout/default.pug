doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{pageTitle} - Admin
    script(src="https://cdn.tailwindcss.com")
    script(src="https://unpkg.com/lucide@latest")
    link(rel="stylesheet", href="/admin/css/style.css")

  body.bg-gray-50
    div.flex.h-screen.bg-gray-50
      //- Sidebar for desktop
      aside.hidden(class="md:flex md:flex-shrink-0")
        div.flex.flex-col.w-64.bg-white.border-r.border-gray-200
          //- Logo
          div.flex.items-center.h-16.px-6.border-b.border-gray-200
            i(data-lucide="camera" class="w-6 h-6 text-blue-600 mr-2")
            h1.text-xl.font-semibold.text-gray-900 Photobooth
          
          //- Navigation
          nav.flex-1.px-3.py-4.space-y-1.overflow-y-auto
            - const navs = [{name: 'Tổng Quan', href: '/admin/dashboard', icon: 'layout-dashboard'}, {name: 'Quản Lý Sự Kiện', href: '/admin/events', icon: 'calendar'}, {name: 'Tạo Sự Kiện', href: '/admin/events/create', icon: 'plus-circle'}, {name: 'Cài Đặt', href: '/admin/settings', icon: 'settings'}]
            each item in navs
              - const isActive = (typeof(path) !== 'undefined' && path.startsWith(item.href)) || false
              a(href=item.href class=`flex items-center px-3 py-2 text-sm rounded-lg transition-colors ${isActive ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}`)
                i(data-lucide=item.icon class="w-5 h-5 mr-3")
                | #{item.name}
          
          //- User profile
          div.border-t.border-gray-200.p-4
            div.flex.items-center
              div.w-10.h-10.rounded-full.bg-blue-600.text-white.flex.items-center.justify-center
                span QT
              div.ml-3.flex-1
                p.text-sm.font-medium.text-gray-900 Quản Trị
                p.text-xs.text-gray-500 admin@photobooth.vn
              i(data-lucide="chevron-down" class="w-4 h-4 text-gray-400")

      //- Mobile sidebar
      div#mobile-sidebar-container.hidden.fixed.inset-0.z-40(class="md:hidden")
        div#mobile-sidebar-overlay.fixed.inset-0.bg-gray-600.bg-opacity-75
        div.fixed.inset-y-0.left-0.flex.flex-col.w-64.bg-white
          div.flex.items-center.h-16.px-6.border-b.border-gray-200
            i(data-lucide="camera" class="w-6 h-6 text-blue-600 mr-2")
            h1.text-xl.font-semibold.text-gray-900 Photobooth
          nav.flex-1.px-3.py-4.space-y-1.overflow-y-auto
            each item in navs
              a.mobile-sidebar-close(href=item.href class="flex items-center px-3 py-2 text-sm rounded-lg transition-colors text-gray-700 hover:bg-gray-50")
                i(data-lucide=item.icon class="w-5 h-5 mr-3")
                | #{item.name}

      //- Main content
      div.flex.flex-col.flex-1.overflow-hidden
        //- Top header
        header.bg-white.border-b.border-gray-200
          div.flex.items-center.justify-between.h-16.px-4(class="sm:px-6 lg:px-8")
            button#mobile-menu-btn.text-gray-500.p-2(class="md:hidden hover:bg-gray-100 rounded-md")
              i(data-lucide="menu" class="w-6 h-6")
            
            div.flex-1.flex.items-center.max-w-md.mx-4
              div.relative.w-full
                i(data-lucide="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400")
                input(type="text" placeholder="Search..." class="pl-10 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-gray-50")
            
            div.flex.items-center.space-x-4
              button.relative.p-2.text-gray-400(class="hover:text-gray-500 hover:bg-gray-100 rounded-full transition")
                i(data-lucide="bell" class="w-5 h-5")
                span.absolute.top-1.right-1.block.h-2.w-2.rounded-full.bg-red-500

        //- Page content
        main.flex-1.overflow-y-auto.bg-gray-50.relative
          //- Flash messages
          if messages && messages.success
            div#flash-message.absolute.top-4.right-4.bg-green-100.border.border-green-400.text-green-700.px-4.py-3.rounded.shadow-lg.z-50(role="alert")
              div.flex.items-center
                i(data-lucide="check-circle" class="w-5 h-5 mr-2")
                span.block.sm_inline= messages.success
          if messages && messages.error
            div#flash-message.absolute.top-4.right-4.bg-red-100.border.border-red-400.text-red-700.px-4.py-3.rounded.shadow-lg.z-50(role="alert")
              div.flex.items-center
                i(data-lucide="alert-circle" class="w-5 h-5 mr-2")
                span.block.sm_inline= messages.error

          div.px-4.py-6(class="sm:px-6 lg:px-8")
            block main

    script(src="/admin/js/script.js")