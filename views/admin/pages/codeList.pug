//- views/admin/pages/sessions/index.pug
extends ../layout/admin.pug 

block content
  .container-fluid.mt-4
    //- Tiêu đề
    .text-center.mb-4
      h2.text-dark(style="color: #5a403d !important; font-weight: 500;") Danh sách mã đã tạo
    
    //- Thống kê nhanh
    .d-flex.justify-content-center.gap-5.mb-4
      div.text-danger.fw-bold.fs-5
        span 💰 Doanh thu: #{totalRevenue.toLocaleString("vi-VN")} 
      div.text-success.fw-bold.fs-5
        span 🎫 Số lượng mã bán: #{totalCount}

    //- =========================================
    //- TÍNH TOÁN NGÀY HÔM NAY (Mặc định cho bộ lọc)
    //- =========================================
    - 
      const now = new Date();
      now.setHours(now.getHours() + 7); // Chỉnh múi giờ VN
      const todayString = now.toISOString().split('T')[0]; // Định dạng yyyy-mm-dd

    //- Bộ lọc (Filter)
    .card.mb-4.border-warning.shadow-sm(style="border-radius: 12px; background: #fffcf8;")
      .card-body
        form(action="" method="GET")
          .row.g-3.align-items-end
            .col-md-2
              label.form-label.fw-bold.text-dark Trạng thái sử dụng
              select.form-select(name="status")
                option(value="") -- Tất cả --
                option(value="UNUSED" selected=(query.status === 'UNUSED')) Chưa dùng
                option(value="COMPLETED" selected=(query.status === 'COMPLETED')) Đã dùng
            
            .col-md-2
              label.form-label.fw-bold.text-dark Mức giá
              select.form-select(name="price")
                option(value="") -- Tất cả --
                each price in uniquePrices
                  option(value=price selected=(query.price == price)) #{price.toLocaleString("vi-VN")}đ
            
            .col-md-2
              label.form-label.fw-bold.text-dark Thanh toán
              select.form-select(name="paymentType")
                option(value="") -- Tất cả --
                option(value="CASH" selected=(query.paymentType === 'CASH')) Tiền mặt
                option(value="BANKING" selected=(query.paymentType === 'BANKING')) Chuyển khoản
            
            .col-md-3
              label.form-label.fw-bold.text-dark Ngày tạo
              //- Nếu query.date có thì giữ nguyên, không thì để trống hoặc bạn có thể điền mặc định todayString
              input.form-control(type="date" name="date" value=query.date)
            
            //- Cột chứa 2 nút (Lọc & Xóa) nới rộng ra col-md-3 để vừa 2 nút
            .col-md-3.d-flex.gap-2
              button.btn.btn-primary.w-50(type="submit") 
                | 🔍 Lọc
              //- Nút xóa lọc: Xóa mọi Query trên URL và gán cứng lại ngày hôm nay
              a.btn.btn-outline-danger.w-50.h-16(href=`/admin/codeList?date=${todayString}`) 
                | ✖ Xóa lọc

    //- Bảng dữ liệu
    .table-responsive.bg-white.shadow-sm.rounded
      //- Đoạn CSS này ép padding 2 bên của tất cả th và td trong bảng nhỏ lại
      style.
        .table-compact th, .table-compact td {
          padding-left: 0.2rem !important;
          padding-right: 0.2rem !important;
        }

      table.table.table-bordered.table-hover.align-middle.mb-0.table-compact(style="font-size: 0.9rem;")
        thead.text-nowrap(style="background-color: #f1ebe5; color: #8b3a33;")
          tr.text-center
            th STT
            th Mã code
            th TT
            th Loại khung
            th Giá
            th Ngày tạo
            th Cập nhật
            th Ghi chú
            th Thanh toán
            th Link
            th Hành động
        
        tbody
          each item, index in records
            tr.text-center
              td #{index + 1}
              td.text-danger.fw-bold.text-nowrap #{item.code}
              
              td
                if item.status === "COMPLETED"
                  span(title="Đã dùng", style="font-size: 1.2rem; cursor: help;") ✅
                else if item.status === "UNUSED"
                  span(title="Chưa dùng", style="font-size: 1.2rem; cursor: help;") ⏳
                else if item.status === "IN_PROGRESS"
                  span(title="Đang chụp", style="font-size: 1.2rem; cursor: help;") 🔄
                else if item.status === "EXPIRED"
                  span(title="Hết hạn", style="font-size: 1.2rem; cursor: help;") ❌
                else
                  span(title=item.status, style="font-size: 1.2rem; cursor: help;") ❓
                  
              td.text-nowrap #{item.paperSize ? item.paperSize.toLowerCase() : item.layoutCode}
              td.text-nowrap #{item.price.toLocaleString("vi-VN")}đ
              
              - const createdStr = new Date(item.createdAt).toLocaleString("vi-VN", { hour12: false })
              td.text-danger.text-nowrap #{createdStr}
              
              - const updatedStr = new Date(item.updatedAt).toLocaleString("vi-VN", { hour12: false })
              td.text-primary.text-nowrap
                if item.createdAt.getTime() === item.updatedAt.getTime()
                  span.text-muted.font-italic Chưa sửa
                else
                  span.fw-bold #{updatedStr}
                  
              td.text-danger.text-start.text-truncate(style="max-width: 150px; cursor: pointer;" title=item.note) #{item.note}
              
              td.text-nowrap
                if item.paymentType === "BANKING"
                  span.text-success(title="Chuyển khoản") 🏦
                else if item.paymentType === "CASH"
                  span.text-success(title="Tiền mặt") 💵
              td.text-nowrap
                a(href=`https://fotolatter.info.vn/${item.code}` target="_blank" style="text-decoration: underline; color: #007bff;") link
              td.text-nowrap
                a.btn.btn-sm.btn-info.me-1(href=`/admin/codeList/detail/${item.id}`) ℹ️
                a.btn.btn-sm.btn-warning(href=`/admin/codeList/edit/${item.id}`) ✏️