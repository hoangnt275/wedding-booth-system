extends ../../layout/default.pug

block main
  //- Mixins for Badges
  mixin packageBadge(type)
    if type === 'premium'
      span.font-medium.text-gray-900 Premium
    else
      span.font-medium.text-gray-900 Basic

  mixin statusBadge(status)
    if status === 'upcoming'
      span.inline-flex.items-center.px-2-5.py-0-5.rounded-md.text-sm.font-medium.bg-blue-100.text-blue-800 Sắp diễn ra
    else if status === 'completed'
      span.inline-flex.items-center.px-2-5.py-0-5.rounded-md.text-sm.font-medium.bg-green-100.text-green-800 Hoàn thành
    else
      span.inline-flex.items-center.px-2-5.py-0-5.rounded-md.text-sm.font-medium.bg-red-100.text-red-800 Đã hủy

  div.space-y-6
    //- Header
    div.flex.items-center.justify-between.flex-wrap.gap-4
      div.flex.items-center.space-x-4
        a.btn.ghost.icon(href="/admin/events" class="p-2 text-gray-400 hover:text-gray-500 hover:bg-gray-100 rounded-md transition")
          i(data-lucide="arrow-left" class="w-5 h-5")
        div
          h2.text-3xl.font-semibold.text-gray-900 Chi Tiết Sự Kiện
          p.text-sm.text-gray-500.mt-1 Xem thông tin chi tiết của sự kiện

      div.flex.space-x-3
        a(href=`/admin/events/edit/${event.id}` class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 flex items-center")
          i(data-lucide="edit" class="w-4 h-4 mr-2 text-gray-500")
          | Chỉnh Sửa
        
        form(action=`/admin/events/delete/${event.id}?_method=DELETE` method="POST" class="form-delete-item m-0 p-0 inline-block")
          button.btn-delete-item(type="button" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 flex items-center")
            i(data-lucide="trash-2" class="w-4 h-4 mr-2")
            | Xóa

    div.grid.gap-6.lg_grid-cols-3(class="lg:grid-cols-3")
      //- Main Info
      div.lg_col-span-2.space-y-6(class="lg:col-span-2")
        div.bg-white.shadow.rounded-lg.border.border-gray-200
          div.px-6.py-5.border-b.border-gray-200
            div.flex.items-start.justify-between.flex-wrap.gap-y-2
              div
                h3.text-2xl.font-semibold.text-gray-900= event.eventName
                span.text-sm.text-gray-500 Mã Sự Kiện: #{event.eventCode || '---'}
                if event.eventType === 'wedding'
                  p.text-gray-500.mt-2.flex.items-center
                    i(data-lucide="heart" class="w-4 h-4 mr-2 text-red-500")
                    | #{event.groomName} & #{event.brideName}
              div
                +statusBadge(event.status)

          div.p-6.space-y-6
            div.grid.gap-6.md_grid-cols-2(class="md:grid-cols-2")
              //- Date
              div.flex.items-start.space-x-3
                div.p-2.bg-blue-50.rounded-lg
                  i(data-lucide="calendar" class="w-5 h-5 text-blue-600")
                div
                  p.text-sm.text-gray-500 Ngày tổ chức
                  p.font-medium.text-gray-900
                    - var d = new Date(event.date)
                    - var formattedDate = [('0'+d.getDate()).slice(-2), ('0'+(d.getMonth()+1)).slice(-2), d.getFullYear()].join("/")
                    | #{formattedDate}
              
              //- Time
              div.flex.items-start.space-x-3
                div.p-2.bg-purple-50.rounded-lg
                  i(data-lucide="clock" class="w-5 h-5 text-purple-600")
                div
                  p.text-sm.text-gray-500 Giờ bắt đầu
                  p.font-medium.text-gray-900= event.time

              //- Package
              div.flex.items-start.space-x-3
                div.p-2.bg-green-50.rounded-lg
                  i(data-lucide="package" class="w-5 h-5 text-green-600")
                div
                  p.text-sm.text-gray-500 Loại gói
                  +packageBadge(event.packageType)

              //- Event Type
              div.flex.items-start.space-x-3
                div.p-2.bg-orange-50.rounded-lg
                  i(data-lucide="calendar-check" class="w-5 h-5 text-orange-600")
                div
                  p.text-sm.text-gray-500 Loại sự kiện
                  p.font-medium.text-gray-900
                    if event.eventType === 'wedding'
                      | Đám cưới
                    else
                      | Sự kiện chung

            //- Location
            div.pt-4.border-t.border-gray-200
              div.flex.items-start.space-x-3
                div.p-2.bg-red-50.rounded-lg
                  i(data-lucide="map-pin" class="w-5 h-5 text-red-600")
                div.flex-1
                  p.text-sm.text-gray-500.mb-1 Địa điểm
                  p.font-medium.text-gray-900= event.location

        //- Additional Info
        div.bg-white.shadow.rounded-lg.border.border-gray-200
          div.px-6.py-5.border-b.border-gray-200
            h3.text-lg.font-medium.leading-6.text-gray-900 Ghi Chú & Yêu Cầu Đặc Biệt
          div.p-6
            if event.note && event.note.trim() !== ''
              p.text-gray-600.whitespace-pre-wrap= event.note
            else
              p.text-gray-600 Không có ghi chú đặc biệt cho sự kiện này.

      //- Contact Info Sidebar
      div.space-y-6
        div.bg-white.shadow.rounded-lg.border.border-gray-200
          div.px-6.py-5.border-b.border-gray-200
            h3.text-lg.font-medium.leading-6.text-gray-900 Thông Tin Liên Hệ
          div.p-6.space-y-4
            div.flex.items-start.space-x-3
              div.p-2.bg-blue-50.rounded-lg
                i(data-lucide="user" class="w-5 h-5 text-blue-600")
              div.flex-1
                p.text-sm.text-gray-500 Người đặt
                p.font-medium.text-gray-900= event.contactName

            div.flex.items-start.space-x-3
              div.p-2.bg-green-50.rounded-lg
                i(data-lucide="phone" class="w-5 h-5 text-green-600")
              div.flex-1
                p.text-sm.text-gray-500 Số điện thoại
                a(href=`tel:${event.phone}` class="font-medium text-blue-600 hover:underline")= event.phone

            div.flex.items-start.space-x-3
              div.p-2.bg-purple-50.rounded-lg
                i(data-lucide="share-2" class="w-5 h-5 text-purple-600")
              div.flex-1
                p.text-sm.text-gray-500 Social Media
                p.font-medium.text-gray-900= event.social || "-"

            div.pt-4.border-t.border-gray-200
              a(href=`tel:${event.phone}` class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 items-center")
                i(data-lucide="phone" class="w-4 h-4 mr-2 text-gray-500")
                | Gọi Điện

        div.bg-white.shadow.rounded-lg.border.border-gray-200
          div.px-6.py-5.border-b.border-gray-200
            h3.text-lg.font-medium.leading-6.text-gray-900 Thống Kê
          div.p-6.space-y-4
            div.flex.justify-between.items-center
              span.text-sm.text-gray-500 Số ảnh chụp
              span.font-semibold.text-gray-900 0
            div.flex.justify-between.items-center
              span.text-sm.text-gray-500 Số khách tham gia
              span.font-semibold.text-gray-900 -
            div.flex.justify-between.items-center
              span.text-sm.text-gray-500 Thời gian chụp
              span.font-semibold.text-gray-900 -
