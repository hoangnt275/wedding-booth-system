extends ../../layout/admin.pug 

block content
  .container-fluid.mt-4.d-flex.justify-content-center
    .card.shadow-sm.border-0(style="width: 100%; max-width: 800px; border-radius: 12px; background: #fffcf8;")
      .card-header.text-white.text-center.py-3(style="background-color: #8b3a33; border-radius: 12px 12px 0 0;")
        h4.mb-0.font-weight-bold ℹ️ Chi tiết mã chụp: #{session.code}
      
      .card-body.p-4
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Trạng thái:
          .col-md-8
            if session.status === "COMPLETED"
              span.badge.bg-success.fs-6 Đã dùng
            else if session.status === "UNUSED"
              span.badge.bg-warning.text-dark.fs-6 Chưa dùng
            else
              span.badge.bg-secondary.fs-6 #{session.status}
              
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Loại giấy (Paper Size):
          .col-md-8 #{session.paperSize}
          
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Layout đã chọn:
          .col-md-8 #{session.layoutCode || "Chưa chọn"}
          
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Giá tiền:
          .col-md-8.text-danger.fw-bold #{session.price.toLocaleString("vi-VN")} đ
          
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Phương thức thanh toán:
          .col-md-8
            if session.paymentType === "BANKING"
              span.text-success Chuyển khoản 🏦
            else
              span.text-success Tiền mặt 💵
              
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Ghi chú:
          .col-md-8.text-danger #{session.note || "Không có ghi chú"}
          
        hr
        
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Thời gian tạo mã:
          .col-md-8 #{new Date(session.createdAt).toLocaleString("vi-VN")}
          
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Khách bắt đầu chụp:
          .col-md-8 #{session.startedAt ? new Date(session.startedAt).toLocaleString("vi-VN") : "Chưa bắt đầu"}
          
        .row.mb-3
          .col-md-4.fw-bold.text-secondary Hoàn thành in ảnh:
          .col-md-8 #{session.endedAt ? new Date(session.endedAt).toLocaleString("vi-VN") : "Chưa hoàn thành"}
          
        .row.mb-4
          .col-md-4.fw-bold.text-secondary Link ảnh Digital:
          .col-md-8 
            if session.digitalPhotoUrl
              a.text-primary(href=session.digitalPhotoUrl target="_blank") Xem ảnh gốc
            else
              span.text-muted Chưa có ảnh

        .text-center
          //- Nhớ sửa lại link quay về danh sách cho đúng route của bạn
          a.btn.btn-secondary.px-4(href="/admin/codeList") ⬅ Quay lại danh sách