extends ../../layout/admin.pug 

block content
  .container-fluid.mt-4.d-flex.justify-content-center
    .card.shadow-sm.border-warning(style="width: 100%; max-width: 800px; border-radius: 12px; background: #fffcf8;")
      .card-header.text-center.py-3(style="background-color: #fcebb6; border-radius: 12px 12px 0 0;")
        h4.mb-0(style="color: #8b3a33; font-weight: bold;") ✏️ Chỉnh sửa thông tin mã
      
      .card-body.p-4
        form(action="" method="POST")
          
          //- HÀNG 1: CÁC THÔNG TIN BỊ KHÓA (CHỈ ĐỌC)
          .row.mb-4.pb-3(style="border-bottom: 1px dashed #ccc;")
            .col-md-4
              label.form-label.text-muted Mã Code
              input.form-control.bg-light.text-muted(type="text" value=session.code readonly)
            
            .col-md-4
              label.form-label.text-muted Trạng thái
              - const statusText = session.status === 'COMPLETED' ? 'Đã dùng' : (session.status === 'UNUSED' ? 'Chưa dùng' : session.status)
              input.form-control.bg-light.text-muted(type="text" value=statusText readonly)

            .col-md-4
              label.form-label.text-muted Layout Code
              input.form-control.bg-light.text-muted(type="text" value=(session.layoutCode || "Chưa chọn") readonly)

          //- HÀNG 2: CÁC THÔNG TIN ĐƯỢC PHÉP SỬA
          .row.mb-3
            .col-md-6
              label.form-label.fw-bold Loại giấy (Paper Size)
              select.form-select(name="paperSize")
                option(value="SMALL" selected=(session.paperSize === "SMALL")) SMALL
                option(value="LARGE" selected=(session.paperSize === "LARGE")) LARGE
            
            .col-md-6
              label.form-label.fw-bold Giá tiền (VNĐ)
              input.form-control(type="number" name="price" value=session.price min="0" required)

          .row.mb-3
            .col-md-6
              label.form-label.fw-bold Hình thức thanh toán
              select.form-select(name="paymentType")
                option(value="CASH" selected=(session.paymentType === "CASH")) Tiền mặt
                option(value="BANKING" selected=(session.paymentType === "BANKING")) Chuyển khoản
            
            .col-md-6
              label.form-label.fw-bold Ghi chú
              textarea.form-control(name="note" rows="2" placeholder="Nhập ghi chú hoặc lý do sửa...") #{session.note}

          //- NÚT HÀNH ĐỘNG
          .d-flex.justify-content-center.gap-3.mt-4
            a.btn.btn-secondary.px-4(href="/admin/codeList") Hủy bỏ
            button.btn.btn-success.px-5(type="submit") 💾 Lưu thay đổi