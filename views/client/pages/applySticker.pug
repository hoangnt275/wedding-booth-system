extends ../layout/default.pug

block main
  .homepage-container
    .edit-container
      .edited-photo
        img(class="final-photo"
          src=finalPhoto
          alt="edited"
          data-frame-type=frameType
          data-selected-frame=selectedFrame
          style="max-height:600px;"
        )

      .filter-group
        if stickerPath
          img(src=stickerPath sticker-item style="max-width:200px")
          .question 
            p.title(style="font-size:30px") Bạn có muốn thêm sticker này vào khung ảnh không?
            .question-actions
              button.yes-btn YES
              button.no-btn NO
        else
          p.title Sticker AI đang trong quá trình phát triển, vui lòng ấn "Hoàn thành" để in ảnh và nhận file ảnh.
    button.btn-guide.btn-finish Hoàn thành

  <script type="module" src="/js/attach-sticker.js"></script>
