extends ../layout/base.pug
include ../mixins/button.pug

block layout
  //- Header chỉ có logo (Hiện đầu tiên, không có delay)
  header(class="animate-fade-up absolute top-0 left-0 w-full px-12 py-10 flex justify-between items-start z-10")
    div.logo-container
      img(src="/ui/logo.png" alt="Foto Latter" class="h-48 object-contain")

  //- Nội dung trung tâm
  main(class="w-full h-full flex flex-col items-center justify-center relative z-0")
    
    //- Gom ngày tháng và tiêu đề vào 1 div để chạy hiệu ứng cùng lúc (Hiện thứ 2)
    div(class="animate-fade-up delay-100 flex flex-col items-center w-full")
      //- Ngày tháng
      div(class="text-6xl font-playfair text-main mb-2 tracking-[0.15em]") 29.04.2026
      //- Tiêu đề chính 
      div(class="mb-8 flex justify-center mt-2")
        img(src="/ui/savethedate.png" alt="Save the date!" class="h-[200px] object-contain")
    
    //- Cụm thông tin Cô dâu & Chú rể (Hiện thứ 3)
    div(class="animate-fade-up delay-200 flex justify-center items-start gap-12 w-full max-w-5xl mt-4")
      //- Cô dâu
      div(class="flex flex-col items-center flex-1")
        h3(class="text-5xl font-pinyon text-main mb-2") Cô dâu
        p(class="text-xl font-sans text-main font-bold tracking-[0.2em] mb-6") BRIDE
        p(class="text-6xl font-pinyon text-main text-center leading-tight") Trần Nguyễn<br>Thu Hương
      
      //- Dấu "&"
      div(class="flex flex-col items-center justify-center pt-12")
        span(class="text-7xl font-pinyon text-main") &
      
      //- Chú rể
      div(class="flex flex-col items-center flex-1")
        h3(class="text-5xl font-pinyon text-main mb-2") Chú rể
        p(class="text-xl font-sans text-main font-bold tracking-[0.2em] mb-6") GROOM
        p(class="text-6xl font-pinyon text-main text-center leading-tight") Nguyễn Tuấn Anh

  //- Footer (Hiện cuối cùng)
  footer(class="animate-fade-up delay-300 absolute bottom-0 left-0 w-full px-12 py-10 flex justify-between items-end z-10")
    div(class="w-1/3 flex justify-start")
      p(class="text-2xl font-sans text-main") 30/300
    
    div(class="w-1/3 flex justify-center")
      //- Sử dụng mixin button với class tuỳ chỉnh kích thước lớn
      +btn-primary("Bắt đầu", "/select-layout", "px-20 py-4 text-[2.5rem]")
    
    div(class="w-1/3 flex justify-end pb-3")
      p(class="text-xl font-sans text-main") @fotolatter.everafter