//- Kế thừa layout main của bạn
extends ../layout/main

block content
  //- Container căn giữa toàn màn hình
  div(class="w-full h-screen flex items-center justify-center p-8")
    
    //- Khung viền Vintage
    div(class="w-full max-w-[1200px] h-[700px]  rounded-xl p-10 flex gap-8  relative" style="padding-top:100px")
      
      //- Cột trái: Lưới 12 ảnh
      div(class="w-[65%] grid grid-cols-4 gap-4 content-start")
        each photo in photos
          //- Vẫn giữ class photo-item để JS gọi, các class Tailwind bọc trong class=""
          div.photo-item(class="relative cursor-pointer rounded-sm overflow-hidden bg-[#eed690] aspect-[4/3]", data-filename=photo)
            //- Ảnh
            img(class="w-full h-full object-cover", src=`/uploads/raw/${photo}`, alt="Photo")
            //- Lớp phủ đen (mặc định tàng hình: opacity-0)
            div.overlay(class="absolute inset-0 bg-black/70 flex items-center justify-center opacity-0 transition-opacity duration-200")
              span.number(class="text-white text-5xl font-bold")

      //- Cột phải: Text và Nút bấm
      div(class="w-[35%] flex flex-col justify-center items-start pl-6")
        //- h1(class="text-[#fcebb6] text-4xl font-['Playfair_Display'] mb-8 font-bold")
        //-   span(class="font-['Pinyon_Script'] text-5xl mr-2") foto.latter
        //-   | THE FIRST VINTAGE PHOTOBOOTH

        p(class="text-[#fcebb6] text-2xl font-['Playfair_Display'] leading-relaxed mb-12")
          | Khách iu hãy chọn ra 4 tấm ảnh yêu thích nha, thứ tự chọn sẽ là thứ tự sắp xếp ảnh hoàn chỉnh.
        
        button#btn-next(
          class="px-12 py-4 rounded-[20px] border-2 border-[#a67c52] text-[#fcebb6] text-4xl font-['Pinyon_Script'] shadow-[0_4px_15px_rgba(0,0,0,0.5)] transition-all duration-300 opacity-50 cursor-not-allowed",
          disabled,
          style="background: linear-gradient(180deg, #6c3b38, #3b1b1a);"
        ) Tiếp tục

  script(src="/js/image.js")